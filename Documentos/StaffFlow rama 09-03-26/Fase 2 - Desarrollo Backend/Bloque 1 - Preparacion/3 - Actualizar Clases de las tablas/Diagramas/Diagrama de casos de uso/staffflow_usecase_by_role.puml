@startuml staffflow_usecase_by_role
' StaffFlow — Diagrama de Casos de Uso por Rol
' Fase 1 · @author Santiago Castillo · iLERNA TFG DAM 2025/2026

left to right direction

skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor #FAFAFA
  BorderColor     #1A237E
  FontSize        10
}
skinparam actor {
  BorderColor #333333
  FontSize    12
  FontStyle   bold
}
skinparam package {
  FontSize    11
  FontStyle   bold
  BorderColor #888888
}
skinparam ArrowColor     #555555
skinparam ArrowThickness 1

' ── ACTORES ─────────────────────────────────────────
actor "ADMIN\n─────\nAcceso total\nsin perfil\nde empleado"    as A  #B71C1C
actor "ENCARGADO\n─────\nOperativa\ndiaria"                    as E  #1565C0
actor "EMPLEADO\n─────\nSolo sus\npropios datos"               as EM #2E7D32

rectangle "StaffFlow — Sistema" {

  package "Auth\n/api/v1/auth" #F3E5F5 {
    usecase "E01 Login\nE02 Logout\nE03 Cambiar contraseña\nE04 Solicitar reset [público]\nE05 Resetear con token [público]" as MOD_AUTH
  }

  package "Empresa\n/api/v1/empresa" #FBE9E7 {
    usecase "E06 Crear/actualizar empresa\nE07 Consultar configuración" as MOD_EMP
  }

  package "Usuarios\n/api/v1/usuarios" #FFEBEE {
    usecase "E08 Crear · E09 Listar\nE10 Consultar · E11 Activar/desactivar\nE12 Actualizar (PATCH)" as MOD_USR
  }

  package "Empleados\n/api/v1/empleados" #E8EAF6 {
    usecase "E13 Crear · E14 Listar\nE15 Consultar · E16 Buscar\nE17 Actualizar · E18 Parche\nE19 Baja · E20 PIN · E21 NFC" as MOD_EMPL
  }

  package "Fichajes\n/api/v1/fichajes" #E8F5E9 {
    usecase "E22 Registrar manual · E23 Listar\nE24 Consultar · E25 Actualizar\nE26 Por fecha" as MOD_FICH
  }

  package "Pausas\n/api/v1/pausas" #E0F2F1 {
    usecase "E27 Registrar manual\nE28 Listar · E29 Consultar" as MOD_PAUS
  }

  package "Ausencias\n/api/v1/ausencias" #E3F2FD {
    usecase "E30 Planificar · E31 Listar\nE32 Consultar · E33 Actualizar\nE34 Eliminar (no procesada)*" as MOD_AUS
  }

  package "Presencia\n/api/v1/presencia" #ECEFF1 {
    usecase "E35 Tiempo real\nE36 Por empleado · E37 Diario" as MOD_PRES
  }

  package "Saldos\n/api/v1/saldos" #FFFDE7 {
    usecase "E38 Listar · E39 Consultar+año\nE40 Recalcular** · E41 Cierre**" as MOD_SALD
  }

  package "Informes\n/api/v1/informes[/pdf]" #FCE4EC {
    usecase "E42 Mensual · E43 Rango\nE44 Presencia diaria\nE45-E47 PDF firmables" as MOD_INF
  }

  package "Terminal\n/api/v1/terminal  [SIN JWT]" #FFF3E0 {
    usecase "E48 Entrada PIN/NFC\nE49 Salida PIN/NFC\nE50 Iniciar pausa · E51 Finalizar pausa" as MOD_TERM
  }

  package "Sistema\n/api/health" #FAFAFA {
    usecase "E52 Health check [público]" as MOD_HEALTH
  }
}

' ── ADMIN: todos los módulos ─────────────────────────
A --> MOD_AUTH
A --> MOD_EMP
A --> MOD_USR
A --> MOD_EMPL
A --> MOD_FICH
A --> MOD_PAUS
A --> MOD_AUS
A --> MOD_PRES
A --> MOD_SALD
A --> MOD_INF

' ── ENCARGADO: operativa + auth + terminal ────────────
E --> MOD_AUTH
E --> MOD_EMPL
E --> MOD_FICH
E --> MOD_PAUS
E --> MOD_AUS
E --> MOD_PRES
E --> MOD_SALD
E --> MOD_INF
E --> MOD_TERM

' ── EMPLEADO: auth + datos propios + terminal ─────────
EM --> MOD_AUTH
EM --> MOD_FICH
EM --> MOD_AUS
EM --> MOD_SALD
EM --> MOD_INF
EM --> MOD_TERM

note bottom of MOD_AUS
  *E34 DELETE solo si procesado=false
  RNF-L01 -- Decision n2
end note

note bottom of MOD_SALD
  **E40/E41 exclusivos ADMIN
  E38/E39 tambien ENCARGADO y EMPLEADO
  (solo sus propios datos si EMPLEADO)
end note

note bottom of MOD_FICH
  EMPLEADO: solo E24 (su fichaje)
  Spring Security HTTP 403
  si accede a datos ajenos
  Decision n10
end note

legend bottom
  | <back:#B71C1C><color:white> ADMIN </color></back>     | Acceso total -- todos los modulos (sin perfil de empleado, nunca ficha con PIN) |
  | <back:#1565C0><color:white> ENCARGADO </color></back> | Operativa diaria -- gestion + terminal PIN/NFC (tiene perfil de empleado)       |
  | <back:#2E7D32><color:white> EMPLEADO </color></back>  | Solo sus propios datos -- Spring Security bloquea acceso ajeno con HTTP 403     |
  | [publico]                                              | Sin autenticacion -- accesible sin JWT ni PIN                                   |
  | [SIN JWT]                                              | Autenticacion por PIN/NFC -- cadena de seguridad propia (RNF-S05)               |
  | * / **                                                 | Endpoints con restricciones adicionales -- ver notas del diagrama               |
endlegend

@enduml
