@startuml staffflow_usecase_gestion
' StaffFlow — Casos de Uso: Gestión (ADMIN + ENCARGADO)
' Fase 1 · Diagrama A/2
' @author Santiago Castillo · iLERNA TFG DAM 2025/2026

left to right direction

skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor #FAFAFA
  BorderColor     #1A237E
  FontSize        10
}
skinparam actor {
  BorderColor #333333
  FontSize    12
  FontStyle   bold
}
skinparam package {
  FontSize      11
  FontStyle     bold
  BorderColor   #888888
}
skinparam ArrowColor     #555555
skinparam ArrowThickness 1

actor "ADMIN\n──────\nAcceso total\nsin perfil\nde empleado" as A #B71C1C
actor "ENCARGADO\n──────\nOperativa\ndiaria" as E #1565C0

rectangle "StaffFlow — Módulos de Gestión  [requiere JWT]" {

  package "Empresa\n/api/v1/empresa" #FBE9E7 {
    usecase "E06 Crear/actualizar\nE07 Consultar" as MOD_EMP
  }

  package "Usuarios\n/api/v1/usuarios" #FFEBEE {
    usecase "E08 Crear\nE09 Listar\nE10 Consultar\nE11 Activar/desactivar\nE12 Actualizar" as MOD_USR
  }

  package "Empleados\n/api/v1/empleados" #E8EAF6 {
    usecase "E13 Crear · E14 Listar\nE15 Consultar · E16 Buscar\nE17 Actualizar · E18 Parche\nE19 Baja · E20 PIN · E21 NFC" as MOD_EMPL
  }

  package "Fichajes\n/api/v1/fichajes" #E8F5E9 {
    usecase "E22 Registrar manual\nE23 Listar · E24 Consultar\nE25 Actualizar · E26 Por fecha" as MOD_FICH
  }

  package "Pausas\n/api/v1/pausas" #E0F2F1 {
    usecase "E27 Registrar manual\nE28 Listar · E29 Consultar" as MOD_PAUS
  }

  package "Ausencias\n/api/v1/ausencias" #E3F2FD {
    usecase "E30 Planificar · E31 Listar\nE32 Consultar · E33 Actualizar\nE34 Eliminar*" as MOD_AUS
  }

  package "Presencia\n/api/v1/presencia" #ECEFF1 {
    usecase "E35 Tiempo real\nE36 Por empleado · E37 Diario" as MOD_PRES
  }

  package "Saldos\n/api/v1/saldos" #FFFDE7 {
    usecase "E38 Listar · E39 Consultar\nE40 Recalcular* · E41 Cierre*" as MOD_SALD
  }

  package "Informes\n/api/v1/informes[/pdf]" #FCE4EC {
    usecase "E42 Mensual · E43 Rango\nE44 Presencia diaria\nE45–E47 PDF firmables" as MOD_INF
  }
}

' ── ADMIN: todos los módulos ─────────────────────────
A --> MOD_EMP
A --> MOD_USR
A --> MOD_EMPL
A --> MOD_FICH
A --> MOD_PAUS
A --> MOD_AUS
A --> MOD_PRES
A --> MOD_SALD
A --> MOD_INF

' ── ENCARGADO: operativa (sin Empresa, Usuarios, ni\n    gestión exclusiva de Empleados/Saldos) ──────────
E --> MOD_EMPL
E --> MOD_FICH
E --> MOD_PAUS
E --> MOD_AUS
E --> MOD_PRES
E --> MOD_SALD
E --> MOD_INF

note bottom of MOD_AUS
  *E34 DELETE solo si
  procesado=false
  RNF-L01 — Decisión nº2
end note

note bottom of MOD_SALD
  *E40/E41 exclusivos ADMIN
  E38/E39 también ENCARGADO
end note

legend bottom
  | <back:#B71C1C><color:white> ADMIN </color></back>     | Acceso a todos los módulos                          |
  | <back:#1565C0><color:white> ENCARGADO </color></back> | Acceso a módulos operativos (sin Empresa ni Usuarios) |
  | *                                                      | Endpoint exclusivo de ADMIN dentro de módulo compartido |
endlegend

@enduml
