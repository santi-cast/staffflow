@startuml staffflow_usecase_acceso
' StaffFlow — Casos de Uso: Acceso Propio + Terminal (todos los roles)
' Fase 1 · Diagrama B/2
' @author Santiago Castillo · iLERNA TFG DAM 2025/2026

top to bottom direction

skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor #FAFAFA
  BorderColor     #1A237E
  FontSize        11
}
skinparam actor {
  BorderColor #333333
  FontSize    13
  FontStyle   bold
}
skinparam package {
  FontSize  12
  FontStyle bold
}
skinparam ArrowColor  #555555
skinparam ArrowThickness 1

actor "ADMIN"     as A  #B71C1C
actor "ENCARGADO" as E  #1565C0
actor "EMPLEADO"  as EM #2E7D32

rectangle "StaffFlow — Acceso Propio + Terminal" {

  package "Auth  /api/v1/auth" #F3E5F5 {
    usecase "E01 Login"                        as E01
    usecase "E02 Logout"                       as E02
    usecase "E03 Cambiar contraseña propia"    as E03
    usecase "E04 Solicitar reset [público]"    as E04
    usecase "E05 Resetear con token [público]" as E05
  }

  package "Datos propios  /api/v1/..." #E8EAF6 {
    usecase "E15 Mi perfil de empleado"        as P15
    usecase "E24 Mis fichajes"                 as P24
    usecase "E32 Mis ausencias"                as P32
    usecase "E39 Mi saldo anual"               as P39
    usecase "E42 Mi informe mensual"           as P42
    usecase "E43 Mi informe rango"             as P43
    usecase "E45 Mi PDF mensual"               as P45
    usecase "E46 Mi PDF rango"                 as P46
  }

  package "Terminal  /api/v1/terminal  [SIN JWT]" #FFF3E0 {
    usecase "E48 Entrada con PIN/NFC"          as E48
    usecase "E49 Salida con PIN/NFC"           as E49
    usecase "E50 Iniciar pausa"                as E50
    usecase "E51 Finalizar pausa"              as E51
  }

  package "Sistema  /api/health" #ECEFF1 {
    usecase "E52 Health check [público]"       as E52
  }

}

' ── Auth — todos los roles ───────────────────────────
A  --> E01
E  --> E01
EM --> E01
A  --> E02
E  --> E02
EM --> E02
A  --> E03
E  --> E03
EM --> E03
EM --> E04
EM --> E05

' ── Datos propios — EMPLEADO (Spring Security restringe) ─
EM --> P15
EM --> P24
EM --> P32
EM --> P39
EM --> P42
EM --> P43
EM --> P45
EM --> P46

' ── Terminal — EMPLEADO + ENCARGADO (sin JWT) ────────
EM --> E48
EM --> E49
EM --> E50
EM --> E51
E  --> E48
E  --> E49
E  --> E50
E  --> E51

note right of E04
  Token 1 uso, 30 min
  RNF-S04 — Decisión nº9
end note

note right of E48
  HTTP 423 = PIN bloqueado
  5 fallos → 30s bloqueo
  Decisión nº16
end note

note bottom of P15
  EMPLEADO accede solo a sus datos
  Spring Security → HTTP 403
  si intenta acceder a otro ID
  Decisión nº10 y nº14
end note

legend bottom
  | <back:#B71C1C><color:white> ADMIN </color></back>     | Auth (E01–E03) + endpoints propios como cualquier usuario autenticado |
  | <back:#1565C0><color:white> ENCARGADO </color></back> | Auth (E01–E03) + Terminal PIN/NFC (E48–E51)                          |
  | <back:#2E7D32><color:white> EMPLEADO </color></back>  | Auth completa (E01–E05) + datos propios + Terminal PIN/NFC            |
  | [público]                                              | Sin autenticación — accesible sin JWT ni PIN                          |
  | [SIN JWT]                                              | Autenticación por PIN/NFC — cadena de seguridad propia (RNF-S05)      |
  | HTTP 403                                               | Spring Security bloquea acceso a datos de otro empleado (Decisión nº10) |
endlegend
@enduml
