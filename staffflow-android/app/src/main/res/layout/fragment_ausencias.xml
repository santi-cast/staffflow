<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout del resumen de ausencias globales (P23). Patron WebView.

    Endpoint: E-ausencias-global GET /api/v1/informes/ausencias?desde=&hasta=
    Roles: ENCARGADO y ADMIN.

    Estructura:
      - LinearLayout vertical raiz
          Barra superior: navegacion semanal centrada + boton Añadir ausencia a la derecha
          FrameLayout con tres estados:
              CARGANDO: CircularProgressIndicator centrado
              ERROR:    nube + mensaje + boton Reintentar
              EXITO:    WebView con la tabla HTML de ausencias
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Barra superior: añadir ausencia | nav semanal centrada | añadir festivo -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <!-- Boton añadir ausencia: fijado a la izquierda -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnadirAusencia"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ausencias_anadir"
            app:icon="@android:drawable/ic_input_add"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Grupo de navegacion semanal: centrado horizontalmente -->
        <LinearLayout
            android:id="@+id/layoutNavSemana"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintStart_toEndOf="@id/btnAnadirAusencia"
            app:layout_constraintEnd_toStartOf="@id/btnAnadirFestivo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMesAnterior"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingStart="4dp"
                android:paddingEnd="0dp"
                android:layout_marginEnd="12dp"
                android:text="&#171;"
                android:textSize="32sp"
                android:contentDescription="@string/ausencias_mes_anterior" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSemanaAnterior"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingStart="2dp"
                android:paddingEnd="4dp"
                android:text="&#8249;"
                android:textSize="32sp"
                android:contentDescription="Semana anterior" />

            <TextView
                android:id="@+id/tvSemanaLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:textAppearance="?attr/textAppearanceTitleSmall" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSemanaSiguiente"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingStart="4dp"
                android:paddingEnd="2dp"
                android:text="&#8250;"
                android:textSize="32sp"
                android:contentDescription="Semana siguiente" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMesSiguiente"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="4dp"
                android:layout_marginStart="12dp"
                android:text="&#187;"
                android:textSize="32sp"
                android:contentDescription="@string/ausencias_mes_siguiente" />

        </LinearLayout>

        <!-- Boton añadir festivo: fijado a la derecha -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnadirFestivo"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ausencias_anadir_festivo"
            app:icon="@android:drawable/ic_input_add"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Franja info selección: empleado + días por planificar (visible solo con selección activa) -->
    <TextView
        android:id="@+id/tvInfoSeleccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:background="?attr/colorSurfaceVariant"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Contenedor de estados -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ESTADO: CARGANDO -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="visible" />

        <!-- ESTADO: ERROR -->
        <LinearLayout
            android:id="@+id/layoutError"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x2601;"
                android:textSize="64sp"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/tvErrorMensaje"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReintentar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/reintentar" />

        </LinearLayout>

        <!-- ESTADO: EXITO -->
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
