<?xml version="1.0" encoding="utf-8"?>
<!--
    Cabecera del Navigation Drawer.

    Muestra el nombre de la app, el username y el rol del usuario
    autenticado. Los valores se rellenan desde MainActivity tras
    leer el DataStore (username y rol se guardan en el login, E01).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="32dp"
    android:paddingEnd="24dp"
    android:paddingBottom="16dp"
    android:background="?attr/colorPrimary"
    android:contentDescription="@string/nav_header_desc">

    <TextView
        android:id="@+id/tvHeaderAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
        android:textColor="?attr/colorOnPrimary" />

    <TextView
        android:id="@+id/tvHeaderUsername"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="?attr/colorOnPrimary"
        tools:text="admin"
        xmlns:tools="http://schemas.android.com/tools" />

    <TextView
        android:id="@+id/tvHeaderRol"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="?attr/colorOnPrimary"
        android:alpha="0.8"
        tools:text="ADMIN"
        xmlns:tools="http://schemas.android.com/tools" />

</LinearLayout>
