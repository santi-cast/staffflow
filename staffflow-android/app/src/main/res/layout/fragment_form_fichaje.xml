<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout del formulario de fichaje/pausa (P20).

    Patron F - formulario reutilizable para dos variantes:
      Variante FICHAJE: grupoFichaje visible, grupoPausa GONE.
      Variante PAUSA:   grupoPausa visible, grupoFichaje GONE.

    Campos comunes: empleadoId, fecha, observaciones (OBLIGATORIAS RNF-L02).
    El titulo de la toolbar lo establece FormFichajeFragment segun el modo.
    El boton GUARDAR se deshabilita durante la llamada al API (Decision 25).
    Observaciones con helperText para recordar que son obligatorias.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ID de empleado -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmpleadoId"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/form_fichaje_hint_empleado_id"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmpleadoId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:imeOptions="actionNext"
                android:singleLine="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Fecha (yyyy-MM-dd) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilFecha"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/form_fichaje_hint_fecha"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFecha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:imeOptions="actionNext"
                android:singleLine="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- GRUPO FICHAJE: tipo, horaEntrada, horaSalida -->
        <LinearLayout
            android:id="@+id/grupoFichaje"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Tipo fichaje -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTipoFichaje"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/form_fichaje_hint_tipo"
                android:layout_marginBottom="12dp">

                <AutoCompleteTextView
                    android:id="@+id/actvTipoFichaje"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Hora entrada -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilHoraEntrada"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/form_fichaje_hint_hora_entrada"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHoraEntrada"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="time"
                    android:imeOptions="actionNext"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Hora salida -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilHoraSalida"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/form_fichaje_hint_hora_salida"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHoraSalida"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="time"
                    android:imeOptions="actionNext"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- GRUPO PAUSA: tipoPausa, horaInicio, horaFin -->
        <LinearLayout
            android:id="@+id/grupoPausa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Tipo pausa -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTipoPausa"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/form_fichaje_hint_tipo_pausa"
                android:layout_marginBottom="12dp">

                <AutoCompleteTextView
                    android:id="@+id/actvTipoPausa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Hora inicio -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilHoraInicio"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/form_fichaje_hint_hora_inicio"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHoraInicio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="time"
                    android:imeOptions="actionNext"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Hora fin -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilHoraFin"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/form_fichaje_hint_hora_fin"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHoraFin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="time"
                    android:imeOptions="actionNext"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Observaciones (OBLIGATORIAS RNF-L02) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilObservaciones"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/form_fichaje_hint_observaciones"
            app:helperText="@string/form_fichaje_observaciones_helper"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etObservaciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="2"
                android:maxLines="4" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Boton GUARDAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/form_fichaje_guardar" />

        <!-- Indicador de carga -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            android:indeterminate="true" />

    </LinearLayout>
</ScrollView>
