<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout de Mi saldo anual (P09). Destino inicial del rol EMPLEADO.

    Patron C - dato unico solo lectura. Endpoint: E41 GET /saldos/me?anio=

    Tres estados gestionados por visibilidad:
      CARGANDO -> progressIndicator visible, resto GONE
      ERROR    -> layoutError visible, resto GONE
      EXITO    -> scrollContenido visible, resto GONE

    El selector de año se muestra en la toolbar via MenuProvider (menu_mi_saldo.xml).

    Secciones de datos:
      Vacaciones:     derecho / consumidos / disponibles (dias)
      Asuntos propios: derecho / consumidos / disponibles (dias)
      Horas:          esperadas / trabajadas / saldo (horas, saldo en verde o rojo)
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ESTADO: CARGANDO -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="visible" />

    <!-- ESTADO: ERROR -->
    <LinearLayout
        android:id="@+id/layoutError"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☁"
            android:textSize="64sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/tvErrorMensaje"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReintentar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/reintentar" />

    </LinearLayout>

    <!-- ESTADO: EXITO -->
    <ScrollView
        android:id="@+id/scrollContenido"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card: Vacaciones -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvTituloVacaciones"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/saldo_vacaciones_titulo"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_marginBottom="8dp" />

                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaVacacionesAnterior" />
                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaVacacionesAnual" />
                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaVacacionesAnoCurso" />
                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaVacacionesConsumidos" />
                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaVacacionesDisponibles" />
                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaVacacionesPendientesPlanificar" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Asuntos propios -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvTituloAsuntos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/saldo_asuntos_titulo"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_marginBottom="8dp" />

                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaAsuntosAnterior" />
                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaAsuntosAnual" />
                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaAsuntosAnoCurso" />
                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaAsuntosConsumidos" />
                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaAsuntosDisponibles" />
                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaAsuntosPendientesPlanificar" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Horas -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvTituloHoras"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/saldo_horas_titulo"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_marginBottom="8dp" />

                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaHorasEsperadas" />
                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaHorasTrabajadas" />
                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaSaldoHoras" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
