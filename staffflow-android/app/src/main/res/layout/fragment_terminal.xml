<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout del terminal de fichaje (P01). Diseño kiosk premium.

    Zona publica - sin JWT. El empleado se identifica por PIN de 4 digitos.

    Diseño:
      - Fondo gris suave (colorSurfaceVariant) que simula la pared/superficie.
      - MaterialCardView ancha (pantalla menos 32dp de margen) con sombra.
      - Logo, reloj hero 96sp, fecha, 4 circulos PIN.
      - Numpad flat 3x3 con botones cuadrados 76dp.
      - Ultima fila: ⌫ y 0 centrados (sin OK). El 4o digito navega solo.
      - Boton de acceso con cuenta fuera de la tarjeta, al pie.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_variant_light">

    <!-- Tarjeta terminal: ocupa casi toda la pantalla -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTerminal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnIrALogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="28dp"
            android:paddingVertical="32dp">

            <!-- Logo: "Staff" bold + "Flow" thin -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Staff"
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:fontFamily="sans-serif"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Flow"
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:fontFamily="sans-serif-thin"
                    android:textColor="?attr/colorPrimary" />
            </LinearLayout>

            <!-- Reloj hero: 96sp ultra-fino -->
            <TextClock
                android:id="@+id/reloj"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="HH:mm"
                android:format24Hour="HH:mm"
                android:fontFamily="sans-serif-thin"
                android:textSize="96sp"
                android:textColor="?attr/colorOnSurface"
                android:includeFontPadding="false" />

            <!-- Fecha corta: "MIÉ., 4 ABR" -->
            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:letterSpacing="0.2"
                android:layout_marginTop="2dp" />

            <!-- Indicador PIN: 4 circulos -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="28dp">
                <View
                    android:id="@+id/vPin1"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:background="@drawable/bg_pin_vacio"
                    android:layout_marginEnd="20dp" />
                <View
                    android:id="@+id/vPin2"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:background="@drawable/bg_pin_vacio"
                    android:layout_marginEnd="20dp" />
                <View
                    android:id="@+id/vPin3"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:background="@drawable/bg_pin_vacio"
                    android:layout_marginEnd="20dp" />
                <View
                    android:id="@+id/vPin4"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:background="@drawable/bg_pin_vacio" />
            </LinearLayout>

            <!-- Spinner de verificacion del PIN (visible mientras se llama a E52) -->
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <!-- Mensaje de error de PIN (visible cuando E52 devuelve 404/error) -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorError"
                android:visibility="gone" />

            <!--
                Numpad: botones 76x76dp, gap 10dp.
                Grid total: 76*3 + 10*2 = 248dp.
                Ultima fila: ⌫ y 0 centrados dentro del mismo ancho de 248dp.
            -->
            <LinearLayout
                android:id="@+id/layoutNumpad"
                android:layout_width="248dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp">

                <!-- Fila 1: 1  2  3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn1"
                        style="@style/Widget.StaffFlow.PinKey"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:layout_marginEnd="10dp"
                        android:text="1" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn2"
                        style="@style/Widget.StaffFlow.PinKey"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:layout_marginEnd="10dp"
                        android:text="2" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn3"
                        style="@style/Widget.StaffFlow.PinKey"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:text="3" />
                </LinearLayout>

                <!-- Fila 2: 4  5  6 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn4"
                        style="@style/Widget.StaffFlow.PinKey"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:layout_marginEnd="10dp"
                        android:text="4" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn5"
                        style="@style/Widget.StaffFlow.PinKey"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:layout_marginEnd="10dp"
                        android:text="5" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn6"
                        style="@style/Widget.StaffFlow.PinKey"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:text="6" />
                </LinearLayout>

                <!-- Fila 3: 7  8  9 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn7"
                        style="@style/Widget.StaffFlow.PinKey"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:layout_marginEnd="10dp"
                        android:text="7" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn8"
                        style="@style/Widget.StaffFlow.PinKey"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:layout_marginEnd="10dp"
                        android:text="8" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn9"
                        style="@style/Widget.StaffFlow.PinKey"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:text="9" />
                </LinearLayout>

                <!--
                    Fila 4: ⌫ y 0 centrados.
                    Ancho fila = 240dp. Dos botones = 76+6+76 = 158dp.
                    Margen izquierdo = (240-158)/2 = 41dp para centrar.
                -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLimpiar"
                        style="@style/Widget.StaffFlow.PinKey"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:layout_marginEnd="10dp"
                        android:text="⌫"
                        android:textSize="22sp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn0"
                        style="@style/Widget.StaffFlow.PinKey"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:text="0" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Acceso con cuenta: fuera de la tarjeta, al pie -->
    <TextView
        android:id="@+id/btnIrALogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:text="@string/terminal_btn_login"
        android:textColor="?attr/colorPrimary"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
