<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout de la vista de ausencias del empleado autenticado (P11) — variante WebView.

    Estructura:
      - ChipGroup con dos chips siempre visibles:
          chipPeriodo: selector de rango de fechas
          chipFiltro:  toggle Todas / Vac. y AP (checkable)
      - FrameLayout con estados:
          CARGANDO: progressIndicator centrado
          ERROR:    layoutError (nube + mensaje + Reintentar)
          EXITO:    WebView con el HTML del informe
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Chips de periodo y filtro -->
    <com.google.android.material.chip.ChipGroup
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        app:singleLine="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipPeriodo"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:chipIcon="@drawable/ic_calendar"
            app:chipIconVisible="true"
            android:text="@string/cargando" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipFiltro"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="true"
            android:checked="false"
            android:text="@string/mis_ausencias_chip_filtro_todas" />

    </com.google.android.material.chip.ChipGroup>

    <!-- Estados -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ESTADO: CARGANDO -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="visible" />

        <!-- ESTADO: ERROR -->
        <LinearLayout
            android:id="@+id/layoutError"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x2601;"
                android:textSize="64sp"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/tvErrorMensaje"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReintentar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/reintentar" />

        </LinearLayout>

        <!-- ESTADO: EXITO -->
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
