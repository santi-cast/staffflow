<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout de Mi hoy (P12). Destino inicial del rol EMPLEADO.

    Patron C - dato unico, empleado autenticado.
    Endpoint: E37 GET /presencia/parte-diario/me -> DetallePresenciaResponse

    Tres estados gestionados por visibilidad:
      CARGANDO -> progressIndicator visible, resto GONE
      ERROR    -> layoutError visible, resto GONE
      EXITO    -> scrollContenido visible, resto GONE

    El ticker de 60s en MiHoyViewModel actualiza el contenido automaticamente
    cuando la jornada esta iniciada o en pausa (sin reiniciar la pantalla).
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ESTADO: CARGANDO -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="visible" />

    <!-- ESTADO: ERROR -->
    <LinearLayout
        android:id="@+id/layoutError"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☁"
            android:textSize="64sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/tvErrorMensaje"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReintentar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/reintentar" />

    </LinearLayout>

    <!-- ESTADO: EXITO -->
    <ScrollView
        android:id="@+id/scrollContenido"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card estado de jornada -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvEstadoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:text="@string/mi_hoy_estado_label"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvEstado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card detalle de horario (visible cuando hay hora de entrada) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHorario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mi_hoy_card_horario"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_marginBottom="8dp" />

                    <include
                        layout="@layout/item_saldo_fila"
                        android:id="@+id/filaHoraEntrada" />

                    <include
                        layout="@layout/item_saldo_fila"
                        android:id="@+id/filaHoraSalida"
                        android:visibility="gone" />

                    <include
                        layout="@layout/item_saldo_fila"
                        android:id="@+id/filaJornadaTotal"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card pausa activa (visible cuando pausaActiva = true) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPausa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mi_hoy_card_pausa"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_marginBottom="8dp" />

                    <include
                        layout="@layout/item_saldo_fila"
                        android:id="@+id/filaPausaEstado" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card lista de pausas del dia (visible cuando hay pausas) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPausas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mi_hoy_card_pausas"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_marginBottom="8dp" />

                    <!-- Filas de pausa se inflan dinamicamente desde MiHoyFragment -->
                    <LinearLayout
                        android:id="@+id/containerPausas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</FrameLayout>
