<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout del formulario de usuario (P32). Solo ADMIN.

    Modo alta   (usuarioId=-1): tilUsername, tilPassword, tilEmail, tilRol, btnGuardar.
    Modo edicion (usuarioId>0): tilUsername (disabled), tilEmail, tilRol,
                                tilActivo (Switch), btnGuardar, btnDesactivar.

    tilPassword solo visible en modo alta.
    tilActivo solo visible en modo edicion.
    btnDesactivar solo visible en modo edicion.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Username -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilUsername"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/form_usuario_hint_username">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:autofillHints="username" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password (solo en modo alta) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/form_usuario_hint_password"
            app:endIconMode="password_toggle">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:autofillHints="password" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Email -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmail"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/form_usuario_hint_email">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:autofillHints="emailAddress" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Rol (dropdown) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRol"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/form_usuario_hint_rol">

            <AutoCompleteTextView
                android:id="@+id/actvRol"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:focusableInTouchMode="false" />

        </com.google.android.material.textfield.TextInputLayout>

        <!--
            Seccion "Perfil de empleado".
            Visible en modo alta cuando rol != ADMIN.
            Oculta en modo edicion (el perfil se edita desde P14/P15).
        -->
        <LinearLayout
            android:id="@+id/layoutPerfilEmpleado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/form_usuario_seccion_perfil"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="12dp" />

            <!-- Nombre -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNombre"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/form_empleado_hint_nombre">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName|textCapWords"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Primer apellido -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilApellido1"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/form_empleado_hint_apellido1">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApellido1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName|textCapWords"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Segundo apellido (opcional) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilApellido2"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/form_empleado_hint_apellido2">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApellido2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName|textCapWords"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- DNI -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDni"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/form_empleado_hint_dni">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDni"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapCharacters"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Categoria (dropdown) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCategoria"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/form_empleado_hint_categoria">
                <AutoCompleteTextView
                    android:id="@+id/actvCategoria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:focusableInTouchMode="false" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Horas semanales -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilJornadaSemanal"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/form_empleado_hint_jornada_semanal">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etJornadaSemanal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Dias de vacaciones -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilVacaciones"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/form_empleado_hint_vacaciones">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etVacaciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Dias de asuntos propios -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilAsuntos"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/form_empleado_hint_asuntos">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAsuntos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Activo (Switch, solo en modo edicion) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilActivo"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="@string/form_usuario_hint_activo"
            android:visibility="gone">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchActivo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:checked="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Boton guardar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/form_usuario_guardar" />

        <!-- Boton desactivar (solo en modo edicion) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDesactivar"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/form_usuario_desactivar"
            android:textColor="?attr/colorError"
            android:visibility="gone"
            app:strokeColor="?attr/colorError" />

        <!-- Indicador de progreso -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:trackCornerRadius="4dp" />

    </LinearLayout>

</ScrollView>
