<?xml version="1.0" encoding="utf-8"?>
<!--
    Item del RecyclerView de lista de ausencias (P23).

    Estructura:
      - Borde izquierdo: pendiente (#6750A4 colorPrimary) / procesada (gris #9E9E9E)
      - Fecha de la ausencia (bold)
      - Tipo de ausencia (bodySmall, muted)
      - Estado (Pendiente/Procesada) alineado a la derecha

    El color del borde se establece desde AusenciaAdapter segun procesado.
    Tap navega a P24 en modo edicion.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="6dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Borde de estado -->
        <View
            android:id="@+id/viewBorde"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:minHeight="56dp" />

        <!-- Fecha y tipo -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTipo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Estado -->
        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingEnd="12dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
