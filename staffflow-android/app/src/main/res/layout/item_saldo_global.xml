<?xml version="1.0" encoding="utf-8"?>
<!--
    Fila de tabla para la lista de saldos globales (P27).

    Mismos pesos que la cabecera de fragment_saldos_globales:
      Nombre (weight 3) | Vacaciones (1) | A.Propios (1) | Saldo horas (1)

    El color de fondo alterna blanco / #f7f8fc segun la posicion (lo hace el adapter).
    El ripple se aplica como foreground para no pisar el background de color.
    La linea divisoria inferior es el borde del propio item.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="11dp"
    android:foreground="?attr/selectableItemBackground"
    android:background="#ffffff"
    android:minHeight="48dp">

    <!-- Nombre del empleado -->
    <TextView
        android:id="@+id/tvNombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="3"
        android:layout_gravity="center_vertical"
        android:textSize="13sp"
        android:textColor="#1a1a2e"
        android:textStyle="bold" />

    <!-- Vacaciones disponibles -->
    <TextView
        android:id="@+id/tvVacaciones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:gravity="center"
        android:textSize="13sp"
        android:textColor="#1a1a2e" />

    <!-- Asuntos propios disponibles -->
    <TextView
        android:id="@+id/tvAsuntos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:gravity="center"
        android:textSize="13sp"
        android:textColor="#1a1a2e" />

    <!-- Saldo de horas (verde / rojo segun signo, aplicado en adapter) -->
    <TextView
        android:id="@+id/tvSaldoHoras"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:gravity="center"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>
