<?xml version="1.0" encoding="utf-8"?>
<!--
    Placeholder de carga para item_presencia.xml.
    Se muestra durante el skeleton loading en P17 (sin spinner).
    5 copias en fragment_parte_diario.xml simulan una lista cargando.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="6dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Placeholder nombre -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <View
                android:layout_width="140dp"
                android:layout_height="14dp"
                android:background="@drawable/bg_skeleton" />

            <View
                android:layout_width="90dp"
                android:layout_height="11dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_skeleton" />

        </LinearLayout>

        <!-- Placeholder hora -->
        <View
            android:layout_width="48dp"
            android:layout_height="14dp"
            android:background="@drawable/bg_skeleton" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
