<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout del detalle de un empleado (P14).

    Patron C - dato unico, solo lectura con acciones.
    Endpoint: E15 GET /empleados/{id}

    Tres estados gestionados por visibilidad:
      CARGANDO -> progressIndicator visible, resto GONE
      ERROR    -> layoutError visible, resto GONE
      EXITO    -> scrollContenido visible, resto GONE

    Secciones de datos:
      Header:   nombre completo + numero empleado + badge activo/baja
      Datos:    DNI, fecha de alta, categoria
      Jornada:  horas semanales, dias vacaciones, dias asuntos propios
      Acciones: chips "Ver saldo" y "Ver fichajes"

    El boton Editar se muestra en la toolbar via MenuProvider (menu_detalle_empleado.xml)
    y solo es visible para ADMIN.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ESTADO: CARGANDO -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="visible" />

    <!-- ESTADO: ERROR -->
    <LinearLayout
        android:id="@+id/layoutError"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☁"
            android:textSize="64sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/tvErrorMensaje"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReintentar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/reintentar" />

    </LinearLayout>

    <!-- ESTADO: EXITO -->
    <ScrollView
        android:id="@+id/scrollContenido"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card: Header - nombre + numero + badge activo -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvNombreCompleto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/tvNumeroEmpleado"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipEstado"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Datos personales -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Datos personales"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_marginBottom="8dp" />

                    <include layout="@layout/item_saldo_fila" android:id="@+id/filaDni" />
                    <include layout="@layout/item_saldo_fila" android:id="@+id/filaFechaAlta" />
                    <include layout="@layout/item_saldo_fila" android:id="@+id/filaCategoria" />
                    <include layout="@layout/item_saldo_fila"
                        android:id="@+id/filaPinTerminal"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Jornada y dias -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jornada"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_marginBottom="8dp" />

                    <include layout="@layout/item_saldo_fila" android:id="@+id/filaJornadaSemanal" />
                    <include layout="@layout/item_saldo_fila" android:id="@+id/filaVacaciones" />
                    <include layout="@layout/item_saldo_fila" android:id="@+id/filaAsuntosPropios" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Acciones rapidas -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Acciones"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipVerSaldo"
                            style="@style/Widget.Material3.Chip.Suggestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detalle_empleado_ver_saldo" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipVerFichajes"
                            style="@style/Widget.Material3.Chip.Suggestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detalle_empleado_ver_fichajes" />

                    </com.google.android.material.chip.ChipGroup>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
