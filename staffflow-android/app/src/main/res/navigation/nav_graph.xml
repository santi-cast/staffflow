<?xml version="1.0" encoding="utf-8"?>
<!--
    Grafo de navegacion de StaffFlow.

    Destino raiz: terminalFragment (P01).
    La app arranca siempre en el terminal. Si hay sesion valida en
    DataStore, MainActivity.checkExistingSession() navega directamente
    al destino inicial por rol sin pasar por el login.

    Zona publica (sin Drawer, sin JWT):
      P01 terminalFragment    <- raiz del grafo
      P02 loginFragment
      P03 recoveryFragment
      P05 resetPasswordFragment  <- deep link desde email
      P06 confirmacionFragment   <- feedback terminal (3s -> P01)
      P07 tipoPausaFragment      <- seleccion tipo pausa (-> P01)

    Zona autenticada (con Drawer):
      EMPLEADO:  P08, P09, P10, P11, P12
      ENCARGADO: P13, P14, P15, P17, P18, P19, P20, P23, P24, P26, P27, P28
      ADMIN:     P31, P32, P34
      TODOS:     P04

    Las acciones de navegacion se anadiran en cada bloque conforme
    se implementen los fragments. En el Bloque 1 solo se definen
    las acciones del flujo del terminal (P01 <-> P06 <-> P07).
-->
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/terminalFragment">

    <!-- ============================================================ -->
    <!-- ZONA PUBLICA - SIN JWT                                        -->
    <!-- ============================================================ -->

    <!-- P01 Terminal de fichaje (raiz publica) -->
    <fragment
        android:id="@+id/terminalFragment"
        android:name="com.staffflow.android.ui.fichaje.TerminalFragment"
        android:label=""
        tools:layout="@layout/fragment_terminal">

        <!-- P01 -> P06 Bienvenida (tras introducir el PIN de 4 digitos) -->
        <action
            android:id="@+id/action_terminal_to_confirmacion"
            app:destination="@id/confirmacionFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />

        <!-- P01 -> P02 Login (acceso a la zona autenticada) -->
        <action
            android:id="@+id/action_terminal_to_login"
            app:destination="@id/loginFragment" />

    </fragment>

    <!-- P06 Bienvenida y confirmacion de fichaje -->
    <fragment
        android:id="@+id/confirmacionFragment"
        android:name="com.staffflow.android.ui.fichaje.ConfirmacionFragment"
        android:label=""
        tools:layout="@layout/fragment_confirmacion">

        <!-- P06 -> P01 (cancelar o retorno automatico tras 5 segundos) -->
        <action
            android:id="@+id/action_confirmacion_to_terminal"
            app:destination="@id/terminalFragment"
            app:popUpTo="@id/terminalFragment"
            app:popUpToInclusive="true" />

        <!-- P06 -> P07 Tipo pausa (el usuario quiere iniciar una pausa) -->
        <action
            android:id="@+id/action_confirmacion_to_tipo_pausa"
            app:destination="@id/tipoPausaFragment" />

    </fragment>

    <!-- P07 Seleccion de tipo de pausa (usa popBackStack para volver a P06) -->
    <fragment
        android:id="@+id/tipoPausaFragment"
        android:name="com.staffflow.android.ui.fichaje.TipoPausaFragment"
        android:label="Tipo de pausa"
        tools:layout="@layout/fragment_tipo_pausa" />

    <!-- P02 Login JWT -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.staffflow.android.ui.login.LoginFragment"
        android:label="Iniciar sesión"
        tools:layout="@layout/fragment_login">

        <!-- P02 -> P03 Recuperar contrasena -->
        <action
            android:id="@+id/action_login_to_recovery"
            app:destination="@id/recoveryFragment" />

    </fragment>

    <!-- P03 Recuperar contrasena -->
    <fragment
        android:id="@+id/recoveryFragment"
        android:name="com.staffflow.android.ui.login.RecoveryFragment"
        android:label="Recuperar contraseña"
        tools:layout="@layout/fragment_recovery" />

    <!-- P05 Restablecer contrasena con token por email (deep link) -->
    <fragment
        android:id="@+id/resetPasswordFragment"
        android:name="com.staffflow.android.ui.login.ResetPasswordFragment"
        android:label="Restablecer contraseña"
        tools:layout="@layout/fragment_reset_password">

        <deepLink app:uri="staffflow://reset-password?token={token}" />

        <!-- P05 -> P02 (tras restablecer correctamente o enlace caducado) -->
        <action
            android:id="@+id/action_reset_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />

    </fragment>

    <!-- ============================================================ -->
    <!-- ZONA AUTENTICADA -TODOS LOS ROLES                           -->
    <!-- ============================================================ -->

    <!-- P04 Cambiar contrasena (acceso desde Drawer -> Ajustes) -->
    <fragment
        android:id="@+id/cambiarPasswordFragment"
        android:name="com.staffflow.android.ui.login.CambiarPasswordFragment"
        android:label="Cambiar contraseña"
        tools:layout="@layout/fragment_cambiar_password" />

    <!-- ============================================================ -->
    <!-- ZONA AUTENTICADA -EMPLEADO                                  -->
    <!-- ============================================================ -->

    <!-- P08 Mi perfil -->
    <fragment
        android:id="@+id/miPerfilFragment"
        android:name="com.staffflow.android.ui.empleado.MiPerfilFragment"
        android:label="Mi perfil"
        tools:layout="@layout/fragment_mi_perfil" />

    <!-- P09 Mi saldo anual (destino inicial EMPLEADO) -->
    <fragment
        android:id="@+id/miSaldoFragment"
        android:name="com.staffflow.android.ui.empleado.MiSaldoFragment"
        android:label="Mi saldo"
        tools:layout="@layout/fragment_mi_saldo" />

    <!-- P10 Mis fichajes -->
    <fragment
        android:id="@+id/misFichajesFragment"
        android:name="com.staffflow.android.ui.empleado.MisFichajesFragment"
        android:label="Mis fichajes"
        tools:layout="@layout/fragment_mis_fichajes" />

    <!-- P11 Mis ausencias planificadas -->
    <fragment
        android:id="@+id/misAusenciasFragment"
        android:name="com.staffflow.android.ui.empleado.MisAusenciasFragment"
        android:label="Mis ausencias"
        tools:layout="@layout/fragment_mis_ausencias" />

    <!-- P12 Mi hoy (estado del dia del empleado) -->
    <fragment
        android:id="@+id/miHoyFragment"
        android:name="com.staffflow.android.ui.empleado.MiHoyFragment"
        android:label="Hoy"
        tools:layout="@layout/fragment_mi_hoy" />

    <!-- ============================================================ -->
    <!-- ZONA AUTENTICADA -ENCARGADO y ADMIN                        -->
    <!-- ============================================================ -->

    <!-- P17 Parte diario de presencia (destino inicial ENCARGADO) -->
    <fragment
        android:id="@+id/parteDiarioFragment"
        android:name="com.staffflow.android.ui.encargado.ParteDiarioFragment"
        android:label="Parte diario"
        tools:layout="@layout/fragment_parte_diario">

        <!-- P17 -> P18 Sin justificar (via chip) -->
        <action
            android:id="@+id/action_parte_diario_to_sin_justificar"
            app:destination="@id/sinJustificarFragment" />

        <!-- P17 -> P-DetalleDia Timeline completo del dia de un empleado (tap en fila) -->
        <action
            android:id="@+id/action_parte_diario_to_detalle_dia"
            app:destination="@id/detalleDiaFragment" />

        <!-- P17 -> P20 Editar fichaje o pausa desde evento inline del parte diario -->
        <action
            android:id="@+id/action_parte_diario_to_form_fichaje"
            app:destination="@id/formFichajeFragment" />

        <!-- P17 -> P24 Editar ausencia planificada desde evento inline del parte diario -->
        <action
            android:id="@+id/action_parte_diario_to_form_ausencia"
            app:destination="@id/formAusenciaFragment" />

    </fragment>

    <!-- P-DetalleDia Timeline de jornada de un empleado para un dia concreto -->
    <fragment
        android:id="@+id/detalleDiaFragment"
        android:name="com.staffflow.android.ui.encargado.DetalleDiaFragment"
        android:label="Detalle del día"
        tools:layout="@layout/fragment_detalle_dia">

        <!-- P-DetalleDia -> P20 Editar o crear fichaje / pausa -->
        <action
            android:id="@+id/action_detalle_dia_to_form_fichaje"
            app:destination="@id/formFichajeFragment" />

        <!-- P-DetalleDia -> P24 Editar ausencia planificada -->
        <action
            android:id="@+id/action_detalle_dia_to_form_ausencia"
            app:destination="@id/formAusenciaFragment" />

    </fragment>

    <!-- P18 Empleados sin justificar -->
    <fragment
        android:id="@+id/sinJustificarFragment"
        android:name="com.staffflow.android.ui.encargado.SinJustificarFragment"
        android:label="Sin justificar"
        tools:layout="@layout/fragment_sin_justificar">

        <!-- Tap en empleado -> formulario de fichaje manual en modo alta -->
        <action
            android:id="@+id/action_sin_justificar_to_form_fichaje"
            app:destination="@id/formFichajeFragment" />

    </fragment>

    <!-- P19 Resumen semanal de todos los empleados (WebView interactivo) -->
    <fragment
        android:id="@+id/resumenSemanalFragment"
        android:name="com.staffflow.android.ui.encargado.ResumenSemanalFragment"
        android:label="Fichajes"
        tools:layout="@layout/fragment_resumen_semanal">

        <!-- Tap en celda fichaje o pausa -> formulario de edicion -->
        <action
            android:id="@+id/action_resumen_to_form_fichaje"
            app:destination="@id/formFichajeFragment" />

        <!-- Tap en celda ausencia -> formulario de edicion -->
        <action
            android:id="@+id/action_resumen_to_form_ausencia"
            app:destination="@id/formAusenciaFragment" />

    </fragment>

    <!-- P19-legacy Lista de fichajes (sin entrada en el drawer) -->
    <fragment
        android:id="@+id/fichajesFragment"
        android:name="com.staffflow.android.ui.encargado.FichajesFragment"
        android:label="Fichajes (legacy)"
        tools:layout="@layout/fragment_fichajes">

        <!-- P19 -> P20 Registro manual (fichaje o pausa) -->
        <action
            android:id="@+id/action_fichajes_to_form_fichaje"
            app:destination="@id/formFichajeFragment" />

    </fragment>

    <!-- P20 Registro manual de fichaje o pausa (formulario reutilizable) -->
    <fragment
        android:id="@+id/formFichajeFragment"
        android:name="com.staffflow.android.ui.encargado.FormFichajeFragment"
        android:label="Registro manual"
        tools:layout="@layout/fragment_form_fichaje" />

    <!-- P23 Lista de ausencias planificadas -->
    <fragment
        android:id="@+id/ausenciasFragment"
        android:name="com.staffflow.android.ui.encargado.AusenciasFragment"
        android:label="Ausencias"
        tools:layout="@layout/fragment_ausencias">

        <!-- P23 -> P24 Crear o editar ausencia -->
        <action
            android:id="@+id/action_ausencias_to_form_ausencia"
            app:destination="@id/formAusenciaFragment" />

    </fragment>

    <!-- P24 Crear o editar ausencia -->
    <fragment
        android:id="@+id/formAusenciaFragment"
        android:name="com.staffflow.android.ui.encargado.FormAusenciaFragment"
        android:label="Ausencia"
        tools:layout="@layout/fragment_form_ausencia" />

    <!-- P26 Saldo anual de un empleado (ENCARGADO/ADMIN) -->
    <fragment
        android:id="@+id/saldoFragment"
        android:name="com.staffflow.android.ui.encargado.SaldoFragment"
        android:label="Saldo"
        tools:layout="@layout/fragment_saldo" />

    <!-- P27 Saldos globales de todos los empleados -->
    <fragment
        android:id="@+id/saldosGlobalesFragment"
        android:name="com.staffflow.android.ui.encargado.SaldosGlobalesFragment"
        android:label="Saldos"
        tools:layout="@layout/fragment_saldos_globales">

        <!-- P27 -> P26 Saldo individual (tap en fila) -->
        <action
            android:id="@+id/action_saldos_globales_to_saldo_individual"
            app:destination="@id/saldoFragment" />

    </fragment>

    <!-- P28 Informes (tabs: horas individual / horas global / saldos) -->
    <fragment
        android:id="@+id/informesFragment"
        android:name="com.staffflow.android.ui.encargado.InformesFragment"
        android:label="Informes"
        tools:layout="@layout/fragment_informes" />

    <!-- ============================================================ -->
    <!-- ZONA AUTENTICADA -ADMIN y ENCARGADO (gestion empleados)    -->
    <!-- ============================================================ -->

    <!-- P13 Lista de empleados (destino inicial ADMIN) -->
    <fragment
        android:id="@+id/empleadosFragment"
        android:name="com.staffflow.android.ui.shared.EmpleadosFragment"
        android:label="Empleados"
        tools:layout="@layout/fragment_empleados">

        <!-- P13 -> P14 Detalle empleado (tap en fila) -->
        <action
            android:id="@+id/action_empleados_to_detalle"
            app:destination="@id/detalleEmpleadoFragment" />

        <!-- P13 -> P15 Crear empleado (FAB) -->
        <action
            android:id="@+id/action_empleados_to_form"
            app:destination="@id/formEmpleadoFragment" />

    </fragment>

    <!-- P14 Detalle de empleado -->
    <fragment
        android:id="@+id/detalleEmpleadoFragment"
        android:name="com.staffflow.android.ui.shared.DetalleEmpleadoFragment"
        android:label="Detalle empleado"
        tools:layout="@layout/fragment_detalle_empleado">

        <!-- P14 -> P15 Editar empleado -->
        <action
            android:id="@+id/action_detalle_to_form_empleado"
            app:destination="@id/formEmpleadoFragment" />

        <!-- P14 -> P26 Ver saldo del empleado -->
        <action
            android:id="@+id/action_detalle_to_saldo_individual"
            app:destination="@id/saldoFragment" />

        <!-- P14 -> InformeFichajesEmpleado (WebView idéntico a P10) -->
        <action
            android:id="@+id/action_detalle_to_fichajes"
            app:destination="@id/informeFichajesEmpleadoFragment" />

        <!-- P14 -> InformeAusenciasEmpleado (WebView idéntico a P11) -->
        <action
            android:id="@+id/action_detalle_to_ausencias"
            app:destination="@id/informeAusenciasEmpleadoFragment" />

    </fragment>

    <!-- Informe de fichajes de un empleado (WebView, igual que P10) -->
    <fragment
        android:id="@+id/informeFichajesEmpleadoFragment"
        android:name="com.staffflow.android.ui.encargado.InformeFichajesEmpleadoFragment"
        android:label="Fichajes"
        tools:layout="@layout/fragment_mis_fichajes" />

    <!-- Informe de ausencias de un empleado (WebView, igual que P11) -->
    <fragment
        android:id="@+id/informeAusenciasEmpleadoFragment"
        android:name="com.staffflow.android.ui.encargado.InformeAusenciasEmpleadoFragment"
        android:label="Ausencias"
        tools:layout="@layout/fragment_mis_ausencias" />

    <!-- P15 Crear o editar empleado -->
    <fragment
        android:id="@+id/formEmpleadoFragment"
        android:name="com.staffflow.android.ui.admin.FormEmpleadoFragment"
        android:label="Empleado"
        tools:layout="@layout/fragment_form_empleado" />

    <!-- ============================================================ -->
    <!-- ZONA AUTENTICADA -ADMIN                                     -->
    <!-- ============================================================ -->

    <!-- P31 Lista de usuarios del sistema -->
    <fragment
        android:id="@+id/usuariosFragment"
        android:name="com.staffflow.android.ui.admin.UsuariosFragment"
        android:label="Usuarios"
        tools:layout="@layout/fragment_usuarios">

        <!-- P31 -> P32 Crear o editar usuario -->
        <action
            android:id="@+id/action_usuarios_to_form_usuario"
            app:destination="@id/formUsuarioFragment" />

    </fragment>

    <!-- P32 Crear o editar usuario -->
    <fragment
        android:id="@+id/formUsuarioFragment"
        android:name="com.staffflow.android.ui.admin.FormUsuarioFragment"
        android:label="Usuario"
        tools:layout="@layout/fragment_form_usuario">

        <!-- P32 -> P15 Crear perfil empleado (snackbar tras crear usuario) -->
        <action
            android:id="@+id/action_form_usuario_to_form_empleado"
            app:destination="@id/formEmpleadoFragment" />

    </fragment>

    <!-- P34 Configuracion de la empresa (singleton) -->
    <fragment
        android:id="@+id/empresaFragment"
        android:name="com.staffflow.android.ui.admin.EmpresaFragment"
        android:label="Mi empresa"
        tools:layout="@layout/fragment_empresa" />

</navigation>
